{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "clonesdev-portfolio",
	"main": "./src/llms-txt-worker/index.ts",
	"compatibility_date": "2025-10-08",
	"compatibility_flags": ["nodejs_compat"],
	"upload_source_maps": true,
	"observability": {
		"enabled": true
	},
	"assets": {
		"directory": "./dist/client",
		"not_found_handling": "single-page-application",
		"run_worker_first": ["/api", "/api/*", "/llms.txt", "/llms-full.txt"]
	},
	"ai": {
		"binding": "AI"
	},
	"kv_namespaces": [
		{
			"binding": "ENRICHMENT_CACHE",
			"id": "7dcf784f07de4b5aa498e724fccf2c9f"
		}
	],
	"vars": {
		"MERCHANT_NAME": "PEGMADEF",
		"MERCHANT_DESCRIPTION": "Product catalog powered by Commerce llms.txt",
		"STORE_CURRENCY": "store_current_github",
		"SHIPPING_POLICY": "both",
		"RETURN_POLICY": "both",
		"SHOPIFY_STORE_DOMAIN": "PEFMADEF.portfolio",
		"MERCHANT_VERTICAL": "general retail",
		"ENRICHMENT_CACHE_TTL": "3600",
		"AI_MODEL": "@cf/google/gemma-4-26b-a4b-it"
	}
}
